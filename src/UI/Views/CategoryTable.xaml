<UserControl x:Class="UI.Views.CategoryTable"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Height="200" Width="300">

    <UserControl.Resources>
        <!-- Local fallback styles to satisfy the StaticResource lookups.
             Replace these with the real MaterialDesign merged dictionaries in App.xaml
             (recommended) when the MaterialDesign packages are available. -->
        <Style x:Key="MaterialDesignRaisedButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"/>
        <Style x:Key="MaterialDesignDataGrid" TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}"/>
    </UserControl.Resources>

    <Grid>
        <StackPanel Margin="16">

            <TextBlock Text="Category List"
               FontSize="20"
               FontWeight="SemiBold"
               Margin="0 0 0 10"/>

            <Button Content="Add Category"
            Style="{StaticResource MaterialDesignRaisedButton}"
            HorizontalAlignment="Left"
            Margin="0 0 0 10"/>

            <DataGrid ItemsSource="{Binding Categories}"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              Style="{StaticResource MaterialDesignDataGrid}">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"
                                Binding="{Binding Id}"
                                Width="100"/>

                    <DataGridTextColumn Header="Name"
                                Binding="{Binding Name}"
                                Width="*"/>
                </DataGrid.Columns>

            </DataGrid>

        </StackPanel>
    </Grid>
</UserControl>